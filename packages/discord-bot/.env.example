# Discord Bot Configuration
# Get these from https://discord.com/developers/applications

# Your Discord bot token (required)
DISCORD_TOKEN=your_bot_token_here

# Your Discord user ID for DM reminders (required)
DISCORD_USER_ID=your_user_id_here

# Optional: Channel ID to post reminders (if not set, uses DM)
DISCORD_CHANNEL_ID=

# Path to Subby backup file (required)
# Linux: ~/.local/share/subby/backup.json
# macOS: ~/Library/Application Support/subby/backup.json
# Windows: %APPDATA%/subby/backup.json
SUBBY_BACKUP_PATH=~/.local/share/subby/subby-backup.json

# Reminder time (24h format, default: 09:00)
REMINDER_TIME=09:00

# Timezone (default: UTC)
TIMEZONE=America/New_York
